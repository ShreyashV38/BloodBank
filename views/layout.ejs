<%# views/layout.ejs — Shared layout for all pages %>
  <!DOCTYPE html>
  <html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <%= typeof title !=='undefined' ? title + ' — Goa Blood Bank' : 'Goa Blood Bank' %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <!-- Sidebar Navigation -->
    <nav class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <i class="fa-solid fa-droplet"></i>
          <span>Goa <strong>Blood Bank</strong></span>
        </div>
        <div class="location-badge">
          <i class="fa-solid fa-location-dot"></i> State of Goa, India
        </div>
      </div>

      <ul class="nav-links">
        <li><a href="/dashboard" class="<%= typeof title !== 'undefined' && title==='Dashboard'  ? 'active' : '' %>"><i
              class="fa-solid fa-gauge-high"></i> Dashboard</a></li>
        <li><a href="/donors" class="<%= typeof title !== 'undefined' && title==='Donors'     ? 'active' : '' %>"><i
              class="fa-solid fa-users"></i> Donors</a></li>
        <li><a href="/inventory"
            class="<%= typeof title !== 'undefined' && title==='Blood Inventory' ? 'active' : '' %>"><i
              class="fa-solid fa-flask-vial"></i> Inventory</a></li>
        <li><a href="/hospitals" class="<%= typeof title !== 'undefined' && title==='Hospitals'  ? 'active' : '' %>"><i
              class="fa-solid fa-hospital"></i> Hospitals</a></li>
        <li><a href="/donations"
            class="<%= typeof title !== 'undefined' && title==='Record Donation' ? 'active' : '' %>"><i
              class="fa-solid fa-hand-holding-droplet"></i> Donations</a></li>
        <li><a href="/requests"
            class="<%= typeof title !== 'undefined' && title==='Blood Requests' ? 'active' : '' %>"><i
              class="fa-solid fa-clipboard-list"></i> Requests</a></li>
        <li><a href="/reports"
            class="<%= typeof title !== 'undefined' && title==='Reports & Analytics' ? 'active' : '' %>"><i
              class="fa-solid fa-chart-bar"></i> Reports</a></li>
      </ul>

      <div class="sidebar-footer">
        <% if (locals.admin) { %>
          <div class="admin-info">
            <div class="avatar">
              <%= admin.fullName.charAt(0).toUpperCase() %>
            </div>
            <div>
              <div class="admin-name">
                <%= admin.fullName %>
              </div>
              <div class="admin-role">
                <%= admin.role %>
              </div>
            </div>
          </div>
          <% } %>
            <a href="/logout" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
      <header class="top-bar">
        <h1 class="page-title">
          <%= typeof title !=='undefined' ? title : '' %>
        </h1>
        <div class="top-bar-right">
          <span class="time-badge"><i class="fa-regular fa-clock"></i> <span id="clock"></span></span>
        </div>
      </header>

      <div class="content-wrapper">
        <%- body %>
      </div>
    </main>

    <script>
      // Live clock
      const clock = document.getElementById('clock');
      if (clock) {
        const tick = () => { clock.textContent = new Date().toLocaleTimeString(); };
        tick(); setInterval(tick, 1000);
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <%- typeof extraScripts !=='undefined' ? extraScripts : '' %>
  </body>

  </html>