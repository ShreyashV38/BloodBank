<%# views/layout.ejs — Enhanced Base Layout %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — Goa Blood Bank</title>
    <meta name="description" content="Goa Blood Bank Management System — Official Portal" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <i class="fa-solid fa-droplet"></i>
                <span>Goa Blood Bank</span>
            </div>
            <div class="location-badge">
                <i class="fa-solid fa-location-dot"></i> State Blood Transfusion Council, Goa
            </div>
        </div>

        <ul class="nav-links">
            <li class="nav-section-label">Main</li>
            <li><a href="/dashboard" class="<%= title === 'Dashboard' ? 'active' : '' %>">
                <i class="fa-solid fa-gauge-high"></i> Dashboard
            </a></li>

            <li class="nav-section-label">Management</li>
            <li><a href="/donors" class="<%= title === 'Donors' || title === 'Add Donor' ? 'active' : '' %>">
                <i class="fa-solid fa-users"></i> Donors
            </a></li>
            <li><a href="/donations" class="<%= title === 'Donations' ? 'active' : '' %>">
                <i class="fa-solid fa-hand-holding-droplet"></i> Donations
            </a></li>
            <li><a href="/inventory" class="<%= title === 'Inventory' ? 'active' : '' %>">
                <i class="fa-solid fa-warehouse"></i> Inventory
            </a></li>

            <li class="nav-section-label">Operations</li>
            <li><a href="/requests" class="<%= title === 'Blood Requests' ? 'active' : '' %>">
                <i class="fa-solid fa-clipboard-list"></i> Requests
            </a></li>
            <li><a href="/hospitals" class="<%= title === 'Hospitals' ? 'active' : '' %>">
                <i class="fa-solid fa-hospital"></i> Hospitals
            </a></li>
            <li><a href="/camps" class="<%= title === 'Donation Camps' ? 'active' : '' %>">
                <i class="fa-solid fa-campground"></i> Camps
            </a></li>

            <li class="nav-section-label">Reports</li>
            <li><a href="/reports" class="<%= title === 'Reports' ? 'active' : '' %>">
                <i class="fa-solid fa-chart-pie"></i> Analytics
            </a></li>

            <% if (typeof admin !== 'undefined' && admin && admin.role === 'Super Admin') { %>
                <li class="nav-section-label">Admin</li>
                <li><a href="/admin/users" class="<%= title === 'User Management' ? 'active' : '' %>">
                    <i class="fa-solid fa-users-gear"></i> Users
                </a></li>
                <li><a href="/admin/audit" class="<%= title === 'System Audit' ? 'active' : '' %>">
                    <i class="fa-solid fa-shield-halved"></i> Audit Log
                </a></li>
            <% } %>
        </ul>

        <div class="sidebar-footer">
            <% if (typeof admin !== 'undefined' && admin) { %>
                <div class="admin-info">
                    <div class="avatar"><%= admin.fullName ? admin.fullName.charAt(0) : '?' %></div>
                    <div>
                        <div class="admin-name"><%= admin.fullName %></div>
                        <div class="admin-role"><%= admin.role %></div>
                    </div>
                </div>
            <% } %>
            <a href="/change-password" class="logout-btn" style="margin-bottom:8px;">
                <i class="fa-solid fa-key"></i> Change Password
            </a>
            <a href="/logout" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i> Sign Out
            </a>
        </div>
    </aside>

    <div class="main-content">
        <div class="top-bar">
            <div class="top-bar-greeting">
                <span class="greeting-text"><span id="greeting">Good evening</span>, welcome back</span>
                <span class="greeting-name">
                    <%= typeof admin !== 'undefined' && admin ? admin.fullName : 'User' %>
                    <span class="role-badge"><%= typeof admin !== 'undefined' && admin ? admin.role : '' %></span>
                </span>
            </div>
            <div class="time-badge">
                <i class="fa-regular fa-clock"></i>
                <span id="clock">Loading...</span>
            </div>
        </div>

        <div class="content-wrapper">
            <%- body %>
        </div>

        <footer class="app-footer">
            Goa Blood Bank System v3.0 &mdash; State Blood Transfusion Council, Goa &mdash; &copy; 2026
        </footer>
    </div>

    <script src="/js/clock.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>