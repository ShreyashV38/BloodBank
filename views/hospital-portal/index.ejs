<%# views/hospital-portal/index.ejs — Hospital self-service portal %>
    <!DOCTYPE html>
    <html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>
            <%= hospital ? hospital.name : 'Hospital Portal' %> — Goa Blood Bank
        </title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
        <link rel="stylesheet" href="/css/style.css" />
    <style>
        /* Hospital portal uses shared portal styles from style.css */
    </style>
    </head>

    <body>
        <div class="portal-wrap">

            <!-- Sidebar -->
            <aside class="portal-sidebar">
                <div class="logo">
                    <i class="fa-solid fa-droplet"></i>
                    <h2>Goa Blood Bank</h2>
                    <p>
                        <%= hospital ? hospital.name : 'Hospital Portal' %>
                    </p>
                </div>
                <nav class="portal-nav">
                    <a href="/hospital-portal" class="active"><i class="fa-solid fa-clipboard-list"></i> My Requests</a>
                </nav>
                <div class="portal-footer">
                    <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="portal-main">
                <div class="portal-header">
                    <h1><i class="fa-solid fa-hospital" style="color:#7f0000"></i>
                        <%= hospital ? hospital.name : 'Hospital Portal' %>
                    </h1>
                    <p>
                        <% if (hospital) { %>
                            <i class="fa-solid fa-location-dot"></i>
                            <%= hospital.address %>, <%= hospital.city %>, Goa
                                    &nbsp;|&nbsp; <i class="fa-solid fa-user"></i>
                                    <%= hospital.contact_person %>
                                        &nbsp;|&nbsp; <i class="fa-solid fa-phone"></i>
                                        <%= hospital.phone %>
                                            <% } %>
                    </p>
                </div>

                <% if (success) { %>
                    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i>
                        <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <!-- Stats row -->
                                <% if (hospital) { %>
                                    <div class="stats-row">
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.filter(r=>r.status==='Pending').length %>
                                            </div>
                                            <div class="lbl">Pending</div>
                                        </div>
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.filter(r=>r.status==='Fulfilled').length %>
                                            </div>
                                            <div class="lbl">Fulfilled</div>
                                        </div>
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.filter(r=>r.urgency==='Critical').length %>
                                            </div>
                                            <div class="lbl">Critical</div>
                                        </div>
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.length %>
                                            </div>
                                            <div class="lbl">Total Requests</div>
                                        </div>
                                    </div>

                                    <!-- New Request Form -->
                                    <div class="card" style="margin-bottom:28px;">
                                        <div class="card-header">
                                            <span class="card-title"><i class="fa-solid fa-plus"></i> Raise New Blood
                                                Request</span>
                                        </div>
                                        <form method="POST" action="/hospital-portal/request">
                                            <div class="form-grid" style="padding:20px;">
                                                <div class="form-group">
                                                    <label>Blood Group *</label>
                                                    <select name="blood_group_id" required>
                                                        <option value="">— Select —</option>
                                                        <% blood_groups.forEach(bg=> { %>
                                                            <option value="<%= bg.blood_group_id %>">
                                                                <%= bg.group_name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label>Units Required *</label>
                                                    <input type="number" name="units_required" min="1" max="50"
                                                        step="0.5" required placeholder="e.g. 2" />
                                                </div>
                                                <div class="form-group">
                                                    <label>Urgency *</label>
                                                    <select name="urgency" required>
                                                        <option value="Normal">Normal</option>
                                                        <option value="Urgent">Urgent</option>
                                                        <option value="Critical">Critical</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label>Required By Date *</label>
                                                    <input type="date" name="required_by_date" required />
                                                </div>
                                                <div class="form-group" style="grid-column:1/-1;">
                                                    <label>Purpose / Reason *</label>
                                                    <input type="text" name="purpose" required
                                                        placeholder="e.g. Emergency surgery, Scheduled transfusion" />
                                                </div>
                                            </div>
                                            <div style="padding:0 20px 20px;">
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="fa-solid fa-paper-plane"></i> Submit Request
                                                </button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Request History -->
                                    <div class="card">
                                        <div class="card-header">
                                            <span class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> My
                                                Request History</span>
                                        </div>
                                        <% if (requests.length===0) { %>
                                            <p style="padding:24px;color:#718096;text-align:center;">No requests raised
                                                yet.</p>
                                            <% } else { %>
                                                <table class="table">
                                                    <thead>
                                                        <tr>
                                                            <th>#</th>
                                                            <th>Blood Group</th>
                                                            <th>Units</th>
                                                            <th>Urgency</th>
                                                            <th>Status</th>
                                                            <th>Required By</th>
                                                            <th>Purpose</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% requests.forEach(r=> {
                                                            let daysClass = 'days-left-ok';
                                                            if (r.days_left <= 1) daysClass='days-left-danger' ; else if
                                                                (r.days_left <=3) daysClass='days-left-warn' ; %>
                                                                <tr>
                                                                    <td>
                                                                        <%= r.request_id %>
                                                                    </td>
                                                                    <td><strong>
                                                                            <%= r.group_name %>
                                                                        </strong></td>
                                                                    <td>
                                                                        <%= r.units_required %>
                                                                    </td>
                                                                    <td><span class="urgency-<%= r.urgency %>">
                                                                            <%= r.urgency %>
                                                                        </span></td>
                                                                    <td>
                                                                        <span
                                                                            class="badge badge-<%= r.status==='Pending'?'warning':r.status==='Fulfilled'?'success':r.status==='Rejected'?'danger':'primary' %>">
                                                                            <%= r.status %>
                                                                        </span>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.required_by_date ? new
                                                                            Date(r.required_by_date).toLocaleDateString('en-IN')
                                                                            : '—' %>
                                                                            <% if (r.required_by_date &&
                                                                                r.status==='Pending' ) { %>
                                                                                <div class="<%= daysClass %>">
                                                                                    (<%= r.days_left>= 0 ? r.days_left +
                                                                                        ' days left' : 'Overdue' %>)
                                                                                </div>
                                                                                <% } %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.purpose || '—' %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                    </tbody>
                                                </table>
                                                <% } %>
                                    </div>
                                    <% } %>
                                        <%# end if hospital %>
            </main>
        </div>
    </body>

    </html>