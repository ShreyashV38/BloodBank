<%# views/hospital-portal/index.ejs — Hospital self-service portal %>
    <!DOCTYPE html>
    <html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>
            <%= hospital ? hospital.name : 'Hospital Portal' %> — Goa Blood Bank
        </title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
        <link rel="stylesheet" href="/css/style.css" />
        <style>
            .portal-wrap {
                display: flex;
                min-height: 100vh;
                background: #f8fafc;
            }

            .portal-sidebar {
                width: 260px;
                background: linear-gradient(180deg, #7f0000, #3d0000);
                color: #fff;
                padding: 0;
                flex-shrink: 0;
            }

            .portal-sidebar .logo {
                padding: 28px 22px 16px;
                border-bottom: 1px solid rgba(255, 255, 255, .1);
            }

            .portal-sidebar .logo h2 {
                font-size: 1.1rem;
                margin: 6px 0 2px;
            }

            .portal-sidebar .logo p {
                font-size: .72rem;
                color: rgba(255, 255, 255, .5);
            }

            .portal-sidebar .logo i {
                font-size: 1.6rem;
                color: #e53e3e;
            }

            .portal-nav {
                padding: 16px 0;
            }

            .portal-nav a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 11px 22px;
                color: rgba(255, 255, 255, .75);
                text-decoration: none;
                font-size: .88rem;
                transition: .2s;
            }

            .portal-nav a:hover,
            .portal-nav a.active {
                background: rgba(255, 255, 255, .1);
                color: #fff;
            }

            .portal-nav .nav-label {
                padding: 10px 22px 4px;
                font-size: .68rem;
                text-transform: uppercase;
                letter-spacing: .08em;
                color: rgba(255, 255, 255, .35);
            }

            .portal-footer {
                margin-top: auto;
                padding: 16px 22px;
                border-top: 1px solid rgba(255, 255, 255, .1);
            }

            .portal-footer a {
                color: rgba(255, 255, 255, .6);
                font-size: .82rem;
                text-decoration: none;
            }

            .portal-footer a:hover {
                color: #fff;
            }

            .portal-main {
                flex: 1;
                padding: 32px;
                overflow-y: auto;
            }

            .portal-header {
                margin-bottom: 28px;
            }

            .portal-header h1 {
                font-size: 1.5rem;
                font-weight: 700;
                color: #1a202c;
            }

            .portal-header p {
                color: #718096;
                font-size: .9rem;
                margin-top: 4px;
            }

            .stats-row {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
                gap: 16px;
                margin-bottom: 28px;
            }

            .stat-box {
                background: #fff;
                border-radius: 12px;
                padding: 20px;
                box-shadow: 0 1px 4px rgba(0, 0, 0, .08);
                text-align: center;
            }

            .stat-box .num {
                font-size: 2rem;
                font-weight: 700;
                color: #7f0000;
            }

            .stat-box .lbl {
                font-size: .78rem;
                color: #718096;
                margin-top: 4px;
            }

            .urgency-Critical {
                color: #c53030;
                font-weight: 600;
            }

            .urgency-Urgent {
                color: #dd6b20;
                font-weight: 600;
            }

            .urgency-Normal {
                color: #2d7d46;
            }

            .days-left-danger {
                color: #c53030;
                font-size: .78rem;
            }

            .days-left-warn {
                color: #dd6b20;
                font-size: .78rem;
            }

            .days-left-ok {
                color: #2d7d46;
                font-size: .78rem;
            }
        </style>
    </head>

    <body>
        <div class="portal-wrap">

            <!-- Sidebar -->
            <aside class="portal-sidebar">
                <div class="logo">
                    <i class="fa-solid fa-droplet"></i>
                    <h2>Goa Blood Bank</h2>
                    <p>
                        <%= hospital ? hospital.name : 'Hospital Portal' %>
                    </p>
                </div>
                <nav class="portal-nav">
                    <a href="/hospital-portal" class="active"><i class="fa-solid fa-clipboard-list"></i> My Requests</a>
                </nav>
                <div class="portal-footer">
                    <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="portal-main">
                <div class="portal-header">
                    <h1><i class="fa-solid fa-hospital" style="color:#7f0000"></i>
                        <%= hospital ? hospital.name : 'Hospital Portal' %>
                    </h1>
                    <p>
                        <% if (hospital) { %>
                            <i class="fa-solid fa-location-dot"></i>
                            <%= hospital.address %>, <%= hospital.city %>, Goa
                                    &nbsp;|&nbsp; <i class="fa-solid fa-user"></i>
                                    <%= hospital.contact_person %>
                                        &nbsp;|&nbsp; <i class="fa-solid fa-phone"></i>
                                        <%= hospital.phone %>
                                            <% } %>
                    </p>
                </div>

                <% if (success) { %>
                    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i>
                        <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <!-- Stats row -->
                                <% if (hospital) { %>
                                    <div class="stats-row">
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.filter(r=>r.status==='Pending').length %>
                                            </div>
                                            <div class="lbl">Pending</div>
                                        </div>
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.filter(r=>r.status==='Fulfilled').length %>
                                            </div>
                                            <div class="lbl">Fulfilled</div>
                                        </div>
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.filter(r=>r.urgency==='Critical').length %>
                                            </div>
                                            <div class="lbl">Critical</div>
                                        </div>
                                        <div class="stat-box">
                                            <div class="num">
                                                <%= requests.length %>
                                            </div>
                                            <div class="lbl">Total Requests</div>
                                        </div>
                                    </div>

                                    <!-- New Request Form -->
                                    <div class="card" style="margin-bottom:28px;">
                                        <div class="card-header">
                                            <span class="card-title"><i class="fa-solid fa-plus"></i> Raise New Blood
                                                Request</span>
                                        </div>
                                        <form method="POST" action="/hospital-portal/request">
                                            <div class="form-grid" style="padding:20px;">
                                                <div class="form-group">
                                                    <label>Blood Group *</label>
                                                    <select name="blood_group_id" required>
                                                        <option value="">— Select —</option>
                                                        <% blood_groups.forEach(bg=> { %>
                                                            <option value="<%= bg.blood_group_id %>">
                                                                <%= bg.group_name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label>Units Required *</label>
                                                    <input type="number" name="units_required" min="1" max="50"
                                                        step="0.5" required placeholder="e.g. 2" />
                                                </div>
                                                <div class="form-group">
                                                    <label>Urgency *</label>
                                                    <select name="urgency" required>
                                                        <option value="Normal">Normal</option>
                                                        <option value="Urgent">Urgent</option>
                                                        <option value="Critical">Critical</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label>Required By Date *</label>
                                                    <input type="date" name="required_by_date" required />
                                                </div>
                                                <div class="form-group" style="grid-column:1/-1;">
                                                    <label>Purpose / Reason *</label>
                                                    <input type="text" name="purpose" required
                                                        placeholder="e.g. Emergency surgery, Scheduled transfusion" />
                                                </div>
                                            </div>
                                            <div style="padding:0 20px 20px;">
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="fa-solid fa-paper-plane"></i> Submit Request
                                                </button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Request History -->
                                    <div class="card">
                                        <div class="card-header">
                                            <span class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> My
                                                Request History</span>
                                        </div>
                                        <% if (requests.length===0) { %>
                                            <p style="padding:24px;color:#718096;text-align:center;">No requests raised
                                                yet.</p>
                                            <% } else { %>
                                                <table class="table">
                                                    <thead>
                                                        <tr>
                                                            <th>#</th>
                                                            <th>Blood Group</th>
                                                            <th>Units</th>
                                                            <th>Urgency</th>
                                                            <th>Status</th>
                                                            <th>Required By</th>
                                                            <th>Purpose</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% requests.forEach(r=> {
                                                            let daysClass = 'days-left-ok';
                                                            if (r.days_left <= 1) daysClass='days-left-danger' ; else if
                                                                (r.days_left <=3) daysClass='days-left-warn' ; %>
                                                                <tr>
                                                                    <td>
                                                                        <%= r.request_id %>
                                                                    </td>
                                                                    <td><strong>
                                                                            <%= r.group_name %>
                                                                        </strong></td>
                                                                    <td>
                                                                        <%= r.units_required %>
                                                                    </td>
                                                                    <td><span class="urgency-<%= r.urgency %>">
                                                                            <%= r.urgency %>
                                                                        </span></td>
                                                                    <td>
                                                                        <span
                                                                            class="badge badge-<%= r.status==='Pending'?'warning':r.status==='Fulfilled'?'success':r.status==='Rejected'?'danger':'primary' %>">
                                                                            <%= r.status %>
                                                                        </span>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.required_by_date ? new
                                                                            Date(r.required_by_date).toLocaleDateString('en-IN')
                                                                            : '—' %>
                                                                            <% if (r.required_by_date &&
                                                                                r.status==='Pending' ) { %>
                                                                                <div class="<%= daysClass %>">
                                                                                    (<%= r.days_left>= 0 ? r.days_left +
                                                                                        ' days left' : 'Overdue' %>)
                                                                                </div>
                                                                                <% } %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.purpose || '—' %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                    </tbody>
                                                </table>
                                                <% } %>
                                    </div>
                                    <% } %>
                                        <%# end if hospital %>
            </main>
        </div>
    </body>

    </html>