<%# views/hospital-portal/walk-in.ejs — Walk-in Donation %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — BloodSync</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <div class="portal-wrap">
        <aside class="portal-sidebar">
            <div class="logo">
                <i class="fa-solid fa-droplet"></i>
                <h2>BloodSync</h2>
                <p><%= hospital ? hospital.name : 'Hospital Portal' %></p>
            </div>
            <nav class="portal-nav">
                <a href="/hospital-portal"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
                <a href="/hospital-portal/appointments"><i class="fa-solid fa-calendar-check"></i> Appointments</a>
                <a href="/hospital-portal/walk-in" class="active"><i class="fa-solid fa-person-walking"></i> Walk-in Donation</a>
                <a href="/hospital-portal/invoices"><i class="fa-solid fa-file-invoice-dollar"></i> Billing & Invoices</a>
                <div class="nav-divider"></div>
                <a href="/profile"><i class="fa-solid fa-user-circle"></i> My Profile</a>
                <a href="/change-password"><i class="fa-solid fa-key"></i> Change Password</a>
            </nav>
            <div class="portal-footer">
                <% if (admin) { %>
                    <div style="margin-bottom:12px;">
                        <div class="admin-name" style="color:#fff;"><%= admin.fullName %></div>
                        <div class="admin-role" style="color:rgba(255,255,255,.5);"><%= admin.role %></div>
                    </div>
                <% } %>
                <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
            </div>
        </aside>

        <main class="portal-main">
            <div class="portal-header">
                <h1><i class="fa-solid fa-person-walking"></i> Walk-in Donation</h1>
                <p>Register an on-the-spot donation for eligible donors at <strong><%= hospital.name %></strong></p>
            </div>

            <% if (error) { %> <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div> <% } %>
            <% if (success) { %> <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div> <% } %>

            <!-- Search Donor Card -->
            <div class="card" style="max-width:700px;">
                <div class="card-header">
                    <span class="card-title"><i class="fa-solid fa-magnifying-glass"></i> Search Donor</span>
                </div>
                <form action="/hospital-portal/walk-in" method="GET">
                    <div class="form-grid" style="grid-template-columns: 1fr auto; align-items:end;">
                        <div class="form-group">
                            <label>Donor Phone Number</label>
                            <input type="text" name="phone" placeholder="Enter 10-digit mobile number" value="<%= searchedPhone || '' %>" required>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
                        </div>
                    </div>
                </form>
            </div>

            <% if (searchedPhone && !donor) { %>
                <div class="alert alert-warning" style="max-width:700px;">
                    <i class="fa-solid fa-triangle-exclamation"></i> No donor found with phone number <strong><%= searchedPhone %></strong>. The donor must be registered in the system first.
                </div>
            <% } %>

            <% if (donor) { %>
                <div class="card" style="max-width:700px;">
                    <div class="card-header">
                        <span class="card-title"><i class="fa-solid fa-user"></i> Donor Found</span>
                    </div>

                    <!-- Donor Profile Summary -->
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:20px; padding:16px; background:var(--bg-color); border-radius:10px;">
                        <div>
                            <div style="color:var(--text-muted); font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Name</div>
                            <div style="font-weight:600; margin-top:4px;"><%= donor.first_name %> <%= donor.last_name %></div>
                        </div>
                        <div>
                            <div style="color:var(--text-muted); font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Blood Group</div>
                            <div style="margin-top:4px;">
                                <span class="blood-badge" style="background:rgba(239,83,80,0.15); color:var(--blood-light); border:1px solid rgba(239,83,80,0.3);">
                                    <%= bloodGroup %>
                                </span>
                            </div>
                        </div>
                        <div>
                            <div style="color:var(--text-muted); font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Eligibility</div>
                            <div style="margin-top:4px;">
                                <% if (donor.is_eligible) { %>
                                    <span style="color:var(--success); font-weight:600;"><i class="fa-solid fa-check-circle"></i> Eligible</span>
                                <% } else { %>
                                    <span style="color:var(--danger); font-weight:600;"><i class="fa-solid fa-times-circle"></i> Not Eligible</span>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <% if (!donor.is_eligible) { %>
                        <div class="alert alert-warning" style="margin:0;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <strong>Cooldown Active:</strong> This donor is currently in the 58-day mandatory rest period and cannot donate.
                        </div>
                    <% } else { %>
                        <!-- Donation Vitals Form -->
                        <div style="border-top:1px solid var(--border-color); padding-top:20px;">
                            <h4 style="margin-bottom:16px; color:var(--text-muted); font-size:.85rem; text-transform:uppercase; letter-spacing:1px;">
                                <i class="fa-solid fa-syringe"></i> Record Donation Vitals
                            </h4>
                            <form action="/hospital-portal/walk-in" method="POST">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
                                <input type="hidden" name="donor_id" value="<%= donor.donor_id %>">

                                <div class="form-grid">
                                    <div class="form-group">
                                        <label>Units Donated <span class="text-danger">*</span></label>
                                        <input type="number" step="0.5" min="0.5" max="2" name="units_donated" required placeholder="1.0">
                                    </div>
                                    <div class="form-group">
                                        <label>Weight (kg) <span class="text-danger">*</span></label>
                                        <input type="number" step="0.1" name="weight" required placeholder="65.0">
                                    </div>
                                    <div class="form-group">
                                        <label>Blood Pressure</label>
                                        <input type="text" name="blood_pressure" placeholder="120/80">
                                    </div>
                                    <div class="form-group">
                                        <label>Hemoglobin (g/dL)</label>
                                        <input type="number" step="0.1" name="hemoglobin_level" placeholder="14.5">
                                    </div>
                                </div>
                                
                                <div style="margin-top:16px;">
                                    <button type="submit" class="btn btn-success"><i class="fa-solid fa-check"></i> Complete Walk-in Donation</button>
                                </div>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
