<%# views/donors/add.ejs — Add donor form (Person 1 page stub) %>
    <% if (error) { %>
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i>
            <%= error %>
        </div>
        <% } %>
            <div class="card">
                <div class="card-header">
                    <span class="card-title"><i class="fa-solid fa-user-plus"></i> Add New Donor</span>
                    <a href="/donors" class="btn btn-outline btn-sm">← Back to Donors</a>
                </div>
                <form method="POST" action="/donors/add">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
                    <div class="form-grid">
                        <div class="form-group">
                            <label>First Name *</label>
                            <input type="text" name="first_name" required placeholder="Arjun" />
                        </div>
                        <div class="form-group">
                            <label>Last Name *</label>
                            <input type="text" name="last_name" required placeholder="Reddy" />
                        </div>
                        <div class="form-group">
                            <label>Date of Birth *</label>
                            <input type="date" name="date_of_birth" required />
                        </div>
                        <div class="form-group">
                            <label>Gender *</label>
                            <select name="gender" required>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Phone *</label>
                            <input type="tel" name="phone" required placeholder="9001111111" maxlength="15" />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" name="email" placeholder="donor@mail.com" />
                        </div>
                        <div class="form-group">
                            <label>Blood Group *</label>
                            <select name="blood_group_id" required>
                                <option value="">— Select —</option>
                                <% (bloodGroups || []).forEach(bg=> { %>
                                    <option value="<%= bg.blood_group_id %>">
                                        <%= bg.group_name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div class="form-group" style="grid-column:1/-1;">
                            <label>Address</label>
                            <textarea name="address" rows="2" placeholder="City, State"></textarea>
                        </div>
                    </div>
                    <div style="margin-top:16px;">
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Register
                            Donor</button>
                    </div>
                </form>
            </div>