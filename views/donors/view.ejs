<%# views/donors/view.ejs — Donor Detail Page %>
<%
function bloodClass(g) {
    const m = {'A+':'bg-a-pos','A-':'bg-a-neg','B+':'bg-b-pos','B-':'bg-b-neg','AB+':'bg-ab-pos','AB-':'bg-ab-neg','O+':'bg-o-pos','O-':'bg-o-neg'};
    return m[g] || '';
}
const age = Math.floor((Date.now() - new Date(donor.date_of_birth).getTime()) / (365.25*24*60*60*1000));
let daysUntil = 0;
if (donor.last_donation_date) {
    const since = Math.floor((Date.now() - new Date(donor.last_donation_date).getTime()) / (24*60*60*1000));
    daysUntil = Math.max(0, 58 - since);
}
%>

<div style="display:flex;gap:12px;margin-bottom:20px;">
    <a href="/donors" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
    <a href="/donors/edit/<%= donor.donor_id %>" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen"></i> Edit</a>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <!-- Profile -->
    <div class="card" style="margin-bottom:0;">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-id-card"></i> Donor Profile</span>
            <span class="blood-badge <%= bloodClass(donor.group_name) %>" style="font-size:1.1rem;padding:6px 16px;">
                <%= donor.group_name %>
            </span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;font-size:.875rem;">
            <div><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Full Name</div>
                <div style="font-weight:600;margin-top:2px;"><%= donor.first_name %> <%= donor.last_name %></div></div>
            <div><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Gender</div>
                <div style="margin-top:2px;"><%= donor.gender %></div></div>
            <div><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Age</div>
                <div style="margin-top:2px;"><%= age %> years</div></div>
            <div><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Date of Birth</div>
                <div style="margin-top:2px;"><%= new Date(donor.date_of_birth).toDateString() %></div></div>
            <div><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Phone</div>
                <div style="margin-top:2px;"><%= donor.phone %></div></div>
            <div><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Email</div>
                <div style="margin-top:2px;"><%= donor.email || '—' %></div></div>
            <div style="grid-column:1/-1;"><div style="color:var(--text-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;">Address</div>
                <div style="margin-top:2px;"><%= donor.address || '—' %></div></div>
        </div>
    </div>

    <!-- Eligibility -->
    <div class="eligibility-card <%= donor.is_eligible ? 'eligible' : 'ineligible' %>" style="margin-bottom:0;">
        <div style="text-align:center;">
            <% if (donor.is_eligible) { %>
                <div class="countdown-circle" style="border:3px solid var(--success);margin-bottom:12px;">
                    <div class="days" style="color:var(--success);">✓</div>
                    <div class="label">Eligible</div>
                </div>
                <h3 style="color:var(--success);margin-bottom:6px;">Can Donate</h3>
                <p style="font-size:.85rem;color:var(--text-muted);">This donor is eligible for blood donation.</p>
            <% } else { %>
                <div class="countdown-circle" style="border:3px solid var(--warning);margin-bottom:12px;">
                    <div class="days" style="color:var(--warning);"><%= daysUntil %></div>
                    <div class="label">Days Left</div>
                </div>
                <h3 style="color:var(--warning);margin-bottom:6px;">Cooling Down</h3>
                <p style="font-size:.85rem;color:var(--text-muted);">
                    Last donated on <%= new Date(donor.last_donation_date).toDateString() %>.
                    Eligible again in <%= daysUntil %> day(s).
                </p>
            <% } %>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:20px;text-align:center;">
            <div class="stat-box"><div class="num"><%= donations.length %></div><div class="lbl">Donations</div></div>
            <div class="stat-box"><div class="num"><%= donations.reduce((s,d) => s + Number(d.units_donated), 0) %></div><div class="lbl">Units</div></div>
        </div>
    </div>
</div>

<!-- Donation History -->
<div class="card">
    <div class="card-header"><span class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> Donation History</span></div>
    <% if (donations.length === 0) { %>
        <p style="color:var(--text-muted);text-align:center;padding:24px;">No donation records.</p>
    <% } else { %>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Date</th><th>Blood Group</th><th>Units</th><th>Location</th><th>Status</th></tr></thead>
            <tbody>
                <% donations.forEach(d => {
                    const sc = {Approved:'badge-success',Collected:'badge-info',Tested:'badge-warning',Rejected:'badge-danger'};
                %>
                <tr>
                    <td><%= new Date(d.donation_date).toDateString() %></td>
                    <td><span class="blood-badge <%= bloodClass(d.group_name) %>"><%= d.group_name %></span></td>
                    <td><%= d.units_donated %></td>
                    <td style="color:var(--text-muted);font-size:.82rem"><%= d.donated_at_location || '—' %></td>
                    <td><span class="badge <%= sc[d.status] || 'badge-gray' %>"><%= d.status %></span></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<!-- Appointments -->
<% if (appointments.length > 0) { %>
<div class="card">
    <div class="card-header"><span class="card-title"><i class="fa-solid fa-calendar"></i> Appointments</span></div>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Date</th><th>Time</th><th>Location</th><th>Status</th></tr></thead>
            <tbody>
                <% appointments.forEach(a => {
                    const sc = {Scheduled:'badge-info',Completed:'badge-success',Cancelled:'badge-danger','No-Show':'badge-warning'};
                %>
                <tr>
                    <td><%= new Date(a.scheduled_date).toDateString() %></td>
                    <td><%= a.time_slot || '—' %></td>
                    <td style="color:var(--text-muted);font-size:.82rem"><%= a.location %></td>
                    <td><span class="badge <%= sc[a.status] || 'badge-gray' %>"><%= a.status %></span></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
