<%# views/reports/index.ejs — Analytics & Reports Dashboard %>

<!-- Page Header -->
<div class="analytics-header">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-chart-pie"></i> Reports & Analytics</h1>
        <p style="color:var(--text-muted);font-size:.88rem;margin-top:4px;">Real-time blood bank performance overview</p>
    </div>
</div>

<!-- Summary Stats -->
<div class="analytics-stats">
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:var(--danger-bg);color:var(--blood-light);border-color:rgba(244,67,54,0.2);">
            <i class="fa-solid fa-hand-holding-droplet"></i>
        </div>
        <div class="analytics-stat-val" data-count="<%= summary.totalDonations %>">0</div>
        <div class="analytics-stat-label">Total Donations</div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:var(--info-bg);color:var(--info);border-color:rgba(33,150,243,0.2);">
            <i class="fa-solid fa-vial"></i>
        </div>
        <div class="analytics-stat-val" data-count="<%= summary.totalUnits %>">0</div>
        <div class="analytics-stat-label">Units Collected</div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:var(--warning-bg);color:var(--warning);border-color:rgba(255,152,0,0.2);">
            <i class="fa-solid fa-clipboard-list"></i>
        </div>
        <div class="analytics-stat-val" data-count="<%= summary.totalRequests %>">0</div>
        <div class="analytics-stat-label">Blood Requests</div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:var(--success-bg);color:var(--success);border-color:rgba(76,175,80,0.2);">
            <i class="fa-solid fa-users"></i>
        </div>
        <div class="analytics-stat-val" data-count="<%= summary.totalDonors %>">0</div>
        <div class="analytics-stat-label">Registered Donors</div>
    </div>
</div>

<!-- Charts Row 1: Stock + Requests -->
<div class="chart-grid">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-chart-bar"></i> Blood Stock Distribution</span>
        </div>
        <div class="chart-container">
            <canvas id="stockChart"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-chart-pie"></i> Request Status Breakdown</span>
        </div>
        <div class="chart-container">
            <canvas id="requestChart"></canvas>
        </div>
    </div>
</div>

<!-- Charts Row 2: Donation Volume + Monthly Trends -->
<div class="chart-grid">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-chart-line"></i> Donation Volume by Blood Group</span>
            <span class="badge badge-info">Approved Only</span>
        </div>
        <div class="chart-container">
            <canvas id="donationChart"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-chart-area"></i> Monthly Donation Trends</span>
            <span class="badge badge-info">Last 6 Months</span>
        </div>
        <div class="chart-container">
            <canvas id="monthlyChart"></canvas>
        </div>
    </div>
</div>

<!-- Top Hospitals Table -->
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa-solid fa-trophy"></i> Top Hospitals by Requests</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Hospital</th>
                    <th>Total Requests</th>
                    <th>Fulfilled</th>
                    <th>Fulfilment Rate</th>
                </tr>
            </thead>
            <tbody>
                <% topHospitals.forEach((h, i) => {
                    const rate = h.total_requests > 0 ? Math.round(h.fulfilled / h.total_requests * 100) : 0;
                %>
                <tr>
                    <td>
                        <% if (i === 0) { %>
                            <span style="color:#FFD700;font-size:1.1rem;"><i class="fa-solid fa-crown"></i></span>
                        <% } else { %>
                            <span style="color:var(--text-muted);font-weight:600;"><%= i + 1 %></span>
                        <% } %>
                    </td>
                    <td style="font-weight:600"><%= h.name %></td>
                    <td><%= h.total_requests %></td>
                    <td><%= h.fulfilled %></td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="stock-bar" style="width:120px">
                                <div class="stock-bar-fill <%= rate >= 70 ? 'fill-good' : rate >= 40 ? 'fill-low' : 'fill-critical' %>"
                                    style="width:<%= rate %>%"></div>
                            </div>
                            <span style="font-weight:600;font-size:.85rem;color:<%= rate >= 70 ? 'var(--success)' : rate >= 40 ? 'var(--warning)' : 'var(--danger)' %>;"><%= rate %>%</span>
                        </div>
                    </td>
                </tr>
                <% }); %>
                <% if (topHospitals.length === 0) { %>
                <tr>
                    <td colspan="5" style="text-align:center;color:var(--text-muted);padding:24px;">No hospital data yet.</td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Chart data as JSON -->
<script type="application/json" id="chartData">
    {
        "stockLabels": <%- JSON.stringify(bloodStock.map(r => r.group_name)) %>,
        "stockData": <%- JSON.stringify(bloodStock.map(r => Number(r.total_units))) %>,
        "reqLabels": <%- JSON.stringify(requestStats.map(r => r.status)) %>,
        "reqData": <%- JSON.stringify(requestStats.map(r => Number(r.count))) %>,
        "donLabels": <%- JSON.stringify(donationStats.map(r => r.group_name)) %>,
        "donData": <%- JSON.stringify(donationStats.map(r => Number(r.total_units || 0))) %>,
        "monthLabels": <%- JSON.stringify(monthlyTrends.map(r => r.month_label)) %>,
        "monthDonations": <%- JSON.stringify(monthlyTrends.map(r => Number(r.donations))) %>,
        "monthUnits": <%- JSON.stringify(monthlyTrends.map(r => Number(r.units))) %>
    }
</script>
<script src="/js/reports.js?v=2"></script>