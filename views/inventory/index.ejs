<%# views/inventory/index.ejs — Blood Inventory with color-coded blood groups %>
<%
function bloodClass(g) {
    const m = {'A+':'bg-a-pos','A-':'bg-a-neg','B+':'bg-b-pos','B-':'bg-b-neg','AB+':'bg-ab-pos','AB-':'bg-ab-neg','O+':'bg-o-pos','O-':'bg-o-neg'};
    return m[g] || '';
}
%>
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa-solid fa-flask-vial"></i> Blood Inventory</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Blood Group</th>
                    <th>Units Available</th>
                    <th>Earliest Expiry</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% (stock || []).forEach(row => {
                    const units = Number(row.total_units);
                    const cls = units <= 3 ? 'badge-danger' : units <= 7 ? 'badge-warning' : 'badge-success';
                    const lbl = units <= 3 ? 'Critical' : units <= 7 ? 'Low' : 'Good';
                %>
                <tr>
                    <td>
                        <span class="blood-badge <%= bloodClass(row.group_name) %>" style="font-size:1rem;">
                            <%= row.group_name %>
                        </span>
                    </td>
                    <td style="font-weight:600"><%= units %> unit(s)</td>
                    <td style="color:var(--text-muted);font-size:.85rem">
                        <%= row.earliest_expiry ? new Date(row.earliest_expiry).toDateString() : '—' %>
                    </td>
                    <td><span class="badge <%= cls %>"><%= lbl %></span></td>
                </tr>
                <% }); %>
                <% if (!stock || stock.length === 0) { %>
                    <tr>
                        <td colspan="4" style="text-align:center;color:var(--text-muted);padding:28px;">
                            No inventory data yet.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>