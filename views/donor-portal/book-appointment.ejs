<%# views/donor-portal/book-appointment.ejs — Book Appointment (Full Portal Layout) %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book Appointment — BloodSync</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <div class="portal-wrap">
        <aside class="portal-sidebar">
            <div class="logo">
                <i class="fa-solid fa-droplet"></i>
                <h2>BloodSync</h2>
                <p>Donor Portal</p>
            </div>
            <nav class="portal-nav">
                <a href="/donor-portal"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
                <a href="/donor-portal/book-appointment" class="active"><i class="fa-solid fa-calendar-plus"></i> Book Appointment</a>
                <div class="nav-divider"></div>
                <a href="/profile"><i class="fa-solid fa-user-circle"></i> My Profile</a>
                <a href="/change-password"><i class="fa-solid fa-key"></i> Change Password</a>
            </nav>
            <div class="portal-footer">
                <% if (admin) { %>
                    <div style="margin-bottom:12px;">
                        <div class="admin-name" style="color:#fff;"><%= admin.fullName %></div>
                        <div class="admin-role" style="color:rgba(255,255,255,.5);"><%= admin.role %></div>
                    </div>
                <% } %>
                <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
            </div>
        </aside>

        <main class="portal-main">
            <div class="portal-header">
                <h1><i class="fa-solid fa-calendar-plus"></i> Book Appointment</h1>
                <p>Schedule your next blood donation at a convenient time and location</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
            <% } %>
            <% if (success) { %>
                <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
            <% } %>

            <% if (!donor.is_eligible) { %>
                <div class="card" style="border-left:3px solid var(--warning);">
                    <div style="display:flex; align-items:center; gap:16px;">
                        <i class="fa-solid fa-triangle-exclamation" style="font-size:2.5rem; color:var(--warning);"></i>
                        <div>
                            <h3 style="color:var(--warning); margin-bottom:6px;">Not Eligible to Book</h3>
                            <p style="color:var(--text-muted); font-size:.9rem;">
                                You are currently in the 58-day cooldown period and cannot book a new appointment right now.
                                Please check back on your eligibility date.
                            </p>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <form action="/donor-portal/book-appointment" method="POST">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />

                    <div class="card">
                        <div class="card-header">
                            <span class="card-title"><i class="fa-solid fa-location-dot"></i> Appointment Details</span>
                        </div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Location / Blood Camp <span class="text-danger">*</span></label>
                                <select name="location" required>
                                    <option value="">Select a location</option>
                                    <% locations.forEach(loc => { %>
                                        <option value="<%= loc %>"><%= loc %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Date <span class="text-danger">*</span></label>
                                <input type="date" name="scheduled_date" required min="<%= new Date(Date.now() + 86400000).toISOString().split('T')[0] %>">
                            </div>
                            <div class="form-group">
                                <label>Time Slot</label>
                                <select name="time_slot">
                                    <option value="">Any Time</option>
                                    <option value="09:00">09:00 AM</option>
                                    <option value="10:00">10:00 AM</option>
                                    <option value="11:00">11:00 AM</option>
                                    <option value="14:00">02:00 PM</option>
                                    <option value="15:00">03:00 PM</option>
                                    <option value="16:00">04:00 PM</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Notes (Optional)</label>
                                <input type="text" name="notes" placeholder="Any specific requirements or medical notes?">
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
                        <a href="/donor-portal" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Confirm Booking</button>
                    </div>
                </form>
            <% } %>
        </main>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
