<%# views/hospitals/edit.ejs — Edit Hospital %>
<% if (error) { %>
    <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
<% } %>

<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa-solid fa-pen"></i> Edit Hospital #<%= hospital.hospital_id %></span>
        <a href="/hospitals" class="btn btn-outline btn-sm">← Cancel</a>
    </div>
    <form method="POST" action="/hospitals/edit/<%= hospital.hospital_id %>">
                <div class="form-grid">
            <div class="form-group">
                <label>Hospital Name *</label>
                <input type="text" name="name" required value="<%= hospital.name %>" />
            </div>
            <div class="form-group">
                <label>City</label>
                <select name="city">
                    <option value="">— Select —</option>
                    <% ['Panaji','Margao','Vasco','Mapusa','Ponda','Calangute','Bicholim','Canacona','Pernem','Quepem'].forEach(c => { %>
                        <option value="<%= c %>" <%= hospital.city === c ? 'selected' : '' %>><%= c %></option>
                    <% }); %>
                </select>
            </div>
            <div class="form-group">
                <label>Phone *</label>
                <input type="tel" name="phone" required value="<%= hospital.phone %>" />
            </div>
            <div class="form-group">
                <label>Contact Person</label>
                <input type="text" name="contact_person" value="<%= hospital.contact_person || '' %>" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="<%= hospital.email || '' %>" />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label>Address</label>
                <textarea name="address" rows="2"><%= hospital.address || '' %></textarea>
            </div>
        </div>
        <div style="margin-top:16px;display:flex;gap:10px;">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Save Changes</button>
            <a href="/hospitals" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
