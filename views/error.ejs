<%# views/error.ejs — Styled error page %>
<% if (typeof layout === 'undefined' || layout === false) { %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — BloodSync</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <div class="login-page">
<% } %>
        <div class="error-page">
            <div class="error-icon">
                <% if (code === 404) { %>
                    <i class="fa-solid fa-map-signs"></i>
                <% } else if (code === 403) { %>
                    <i class="fa-solid fa-shield-halved"></i>
                <% } else { %>
                    <i class="fa-solid fa-triangle-exclamation"></i>
                <% } %>
            </div>
            <div class="error-code"><%= code %></div>
            <h2 class="error-title">
                <% if (code === 404) { %>
                    Page Not Found
                <% } else if (code === 403) { %>
                    Access Denied
                <% } else { %>
                    Something Went Wrong
                <% } %>
            </h2>
            <p class="error-message"><%= message %></p>
            <div class="error-actions">
                <a href="/login" class="btn btn-primary"><i class="fa-solid fa-right-to-bracket"></i> Login Again</a>
            </div>
        </div>
<% if (typeof layout === 'undefined' || layout === false) { %>
    </div>
</body>
</html>
<% } %>
