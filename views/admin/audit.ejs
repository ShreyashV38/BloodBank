<%# views/admin/audit.ejs — Enhanced System Audit Log %>
<div style="margin-bottom:16px; display:flex; justify-content:space-between; align-items:center;">
    <a href="/admin/users" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back to Users</a>
    <a href="/admin/backup" class="btn btn-primary btn-sm"><i class="fa-solid fa-file-export"></i> Export Database (.sql)</a>
</div>

<% if (auditLogs && auditLogs.length > 0) { %>
<!-- Audit Log Table -->
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa-solid fa-shield-halved"></i> Audit Log (Last 50 Events)</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Time</th><th>User</th><th>Action</th><th>Entity</th><th>Details</th><th>IP</th></tr></thead>
            <tbody>
                <% auditLogs.forEach(log => {
                    let actionClass = 'admin';
                    if (log.action.includes('LOGIN_SUCCESS')) actionClass = 'login';
                    else if (log.action.includes('LOGOUT')) actionClass = 'logout';
                    else if (log.action.includes('FAILED') || log.action.includes('LOCKED')) actionClass = 'failed';
                    else if (log.action.includes('SIGNUP')) actionClass = 'signup';
                %>
                <tr>
                    <td style="font-size:.78rem;color:var(--text-muted);white-space:nowrap;">
                        <%= new Date(log.created_at).toLocaleString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                    </td>
                    <td style="font-weight:600;font-size:.85rem;">
                        <%= log.full_name || '—' %>
                        <% if (log.username) { %><br><span style="color:var(--text-muted);font-size:.72rem;">@<%= log.username %></span><% } %>
                    </td>
                    <td><span class="audit-action <%= actionClass %>"><%= log.action %></span></td>
                    <td style="font-size:.82rem;color:var(--text-muted);">
                        <% if (log.entity_type) { %><%= log.entity_type %>#<%= log.entity_id %><% } else { %>—<% } %>
                    </td>
                    <td style="font-size:.82rem;max-width:220px;overflow:hidden;text-overflow:ellipsis;">
                        <%= log.details || '—' %>
                    </td>
                    <td style="font-size:.75rem;color:var(--text-muted);font-family:monospace;"><%= log.ip_address || '—' %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <!-- Recent Donations -->
    <div class="card" style="margin-bottom:0;">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-hand-holding-droplet"></i> Recent Donations</span>
        </div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Date</th><th>Donor</th><th>Status</th></tr></thead>
                <tbody>
                    <% recentDonations.forEach(d => { %>
                    <tr>
                        <td style="font-size:.82rem"><%= new Date(d.date).toDateString() %></td>
                        <td style="font-weight:600"><%= d.actor %></td>
                        <td><span class="badge badge-info"><%= d.detail %></span></td>
                    </tr>
                    <% }); %>
                    <% if (recentDonations.length === 0) { %>
                        <tr><td colspan="3" style="text-align:center;color:var(--text-muted);padding:20px;">None</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Requests -->
    <div class="card" style="margin-bottom:0;">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-clipboard-list"></i> Recent Requests</span>
        </div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Date</th><th>Hospital</th><th>Detail</th></tr></thead>
                <tbody>
                    <% recentRequests.forEach(r => { %>
                    <tr>
                        <td style="font-size:.82rem"><%= new Date(r.date).toDateString() %></td>
                        <td style="font-weight:600"><%= r.actor %></td>
                        <td><span class="badge badge-warning"><%= r.detail %></span></td>
                    </tr>
                    <% }); %>
                    <% if (recentRequests.length === 0) { %>
                        <tr><td colspan="3" style="text-align:center;color:var(--text-muted);padding:20px;">None</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Suspicious Accounts -->
<div class="card">
    <div class="card-header">
        <span class="card-title" style="color:var(--warning);"><i class="fa-solid fa-triangle-exclamation"></i> Accounts with Failed Logins</span>
    </div>
    <% if (recentLogins.length === 0) { %>
        <p style="padding:24px;text-align:center;color:var(--text-muted);">No suspicious activity detected.</p>
    <% } else { %>
    <div class="table-wrap">
        <table>
            <thead><tr><th>User</th><th>Role</th><th>Failed Attempts</th><th>Locked Until</th><th>Action</th></tr></thead>
            <tbody>
                <% recentLogins.forEach(u => {
                    const isLocked = u.locked_until && new Date(u.locked_until) > new Date();
                %>
                <tr>
                    <td style="font-weight:600"><%= u.full_name %> <span style="color:var(--text-muted);">(<%= u.username %>)</span></td>
                    <td><span class="badge badge-info"><%= u.role %></span></td>
                    <td><span class="badge badge-danger"><%= u.failed_login_count %> attempts</span></td>
                    <td>
                        <% if (isLocked) { %>
                            <span class="badge badge-danger"><%= new Date(u.locked_until).toLocaleString() %></span>
                        <% } else { %>
                            <span style="color:var(--text-muted);">Not locked</span>
                        <% } %>
                    </td>
                    <td>
                        <form method="POST" action="/admin/users/unlock/<%= u.user_id %>" style="display:inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <button class="btn btn-warning btn-sm"><i class="fa-solid fa-lock-open"></i> Unlock</button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
