<%# views/auth/login.ejs — Blood-themed login with OTP %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Goa Blood Bank</title>
    <meta name="description" content="Secure login portal for Goa Blood Bank Management System" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <div class="login-page">
        <div class="login-card">
            <div class="login-logo">
                <i class="fa-solid fa-droplet"></i>
                <h2>Goa Blood Bank</h2>
                <p>State of Goa &mdash; Official Portal</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
            <% } %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
            <% } %>

            <form method="POST" action="/login" autocomplete="off" id="loginForm">
                <div class="form-group">
                    <label for="username"><i class="fa-solid fa-user"></i> Username</label>
                    <input type="text" id="username" name="username" required placeholder="Enter your username"
                           minlength="3" maxlength="50" />
                </div>
                <div class="form-group" style="margin-bottom:8px;">
                    <label for="password"><i class="fa-solid fa-lock"></i> Password</label>
                    <input type="password" id="password" name="password" required placeholder="Enter your password"
                           minlength="6" />
                </div>
                <div class="login-links" style="margin-bottom:20px;">
                    <a href="/forgot-password"><i class="fa-solid fa-key"></i> Forgot Password?</a>
                    <a href="/signup"><i class="fa-solid fa-user-plus"></i> Create Account</a>
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;">
                    <i class="fa-solid fa-right-to-bracket"></i> Sign In
                </button>
            </form>
        </div>
    </div>
</body>
</html>