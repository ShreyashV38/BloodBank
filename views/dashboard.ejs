<%# views/dashboard.ejs — Enhanced Admin Dashboard %>
<%
function stockLevel(units) {
    if (units <= 5) return 'critical';
    if (units <= 15) return 'low';
    return 'good';
}
function stockColor(units) {
    if (units <= 5) return 'var(--danger)';
    if (units <= 15) return 'var(--warning)';
    return 'var(--success)';
}
%>

<!-- Welcome Hero -->
<div class="welcome-hero">
    <div>
        <h2><i class="fa-solid fa-droplet" style="color:var(--blood-light);margin-right:8px;"></i> <span id="greeting">Good evening</span>, <%= admin.fullName %></h2>
        <p><i class="fa-solid fa-location-dot"></i> Goa Blood Bank — Admin Dashboard</p>
        <div class="tagline">"Every drop counts. Every donor matters."</div>
    </div>
    <div style="text-align:right;">
        <div style="font-size:2rem;font-weight:800;color:var(--blood-light);"><%= totalDonors %></div>
        <div style="font-size:.78rem;color:var(--text-muted);text-transform:uppercase;">Registered Donors</div>
    </div>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon red"><i class="fa-solid fa-users"></i></div>
        <div>
            <div class="stat-val"><%= totalDonors %></div>
            <div class="stat-label">Total Donors</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-clipboard-list"></i></div>
        <div>
            <div class="stat-val"><%= pendingRequests %></div>
            <div class="stat-label">Pending Requests</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-hospital"></i></div>
        <div>
            <div class="stat-val"><%= totalHospitals %></div>
            <div class="stat-label">Hospitals</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-campground"></i></div>
        <div>
            <div class="stat-val"><%= activeCamps %></div>
            <div class="stat-label">Active Camps</div>
        </div>
    </div>
</div>

<!-- Blood Stock + Quick Actions Row -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:20px;">
    <!-- Blood Stock Grid -->
    <div class="card" style="margin-bottom:0;">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-droplet"></i> Blood Stock</span>
        </div>
        <div class="blood-grid">
            <% bloodStock.forEach(s => { 
                const level = stockLevel(s.total_units);
                const color = stockColor(s.total_units);
            %>
                <div class="blood-mini-card" style="--card-accent: <%= color %>;">
                    <div class="mini-group" style="color:<%= color %>;"><%= s.group_name %></div>
                    <div class="mini-units"><%= s.total_units %> units</div>
                    <div class="mini-status <%= level %>"><%= level %></div>
                </div>
            <% }); %>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card" style="margin-bottom:0;">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-bolt"></i> Quick Actions</span>
        </div>
        <div class="quick-actions">
            <a href="/donors/add" class="quick-tile">
                <i class="fa-solid fa-user-plus"></i> Add Donor
            </a>
            <a href="/requests" class="quick-tile">
                <i class="fa-solid fa-clipboard-list"></i> Requests
            </a>
            <a href="/inventory" class="quick-tile">
                <i class="fa-solid fa-warehouse"></i> Inventory
            </a>
            <a href="/reports" class="quick-tile">
                <i class="fa-solid fa-chart-pie"></i> Reports
            </a>
        </div>
    </div>
</div>

<!-- Recent Activity Feed -->
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> Recent Activity</span>
    </div>
    <% if (recentActivity && recentActivity.length > 0) { %>
        <ul class="activity-feed">
            <% recentActivity.forEach(a => { %>
                <li class="activity-item">
                    <div class="activity-icon <%= a.type === 'donation' ? 'donation' : 'request' %>">
                        <i class="fa-solid <%= a.type === 'donation' ? 'fa-hand-holding-droplet' : 'fa-clipboard-list' %>"></i>
                    </div>
                    <div class="activity-text">
                        <strong><%= a.actor %></strong>
                        <div class="activity-detail"><%= a.detail %></div>
                    </div>
                    <div class="activity-date"><%= new Date(a.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></div>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p style="color:var(--text-muted);text-align:center;padding:24px;">No recent activity.</p>
    <% } %>
</div>

<!-- Expiring / Critical Stock Alert -->
<% const criticalStock = bloodStock.filter(s => s.total_units <= 5); %>
<% if (criticalStock.length > 0) { %>
<div class="card">
    <div class="card-header">
        <span class="card-title" style="color:var(--danger);"><i class="fa-solid fa-triangle-exclamation"></i> Critical Stock Alert</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Blood Group</th><th>Available Units</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
                <% criticalStock.forEach(s => { %>
                <tr>
                    <td><span class="blood-badge" style="background:rgba(244,67,54,0.15);color:var(--danger);border:1px solid rgba(244,67,54,0.3);"><%= s.group_name %></span></td>
                    <td style="font-weight:700;color:var(--danger);"><%= s.total_units %></td>
                    <td><span class="badge badge-danger">Critical</span></td>
                    <td><a href="/requests" class="btn btn-danger btn-sm"><i class="fa-solid fa-plus"></i> Request Units</a></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } %>