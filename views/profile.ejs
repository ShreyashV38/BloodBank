<% if (role !== 'Super Admin' && role !== 'Staff') { %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile — Goa Blood Bank</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <div class="portal-wrap" style="padding:40px;">
        <div style="max-width:800px; margin:0 auto; width:100%;">
            <a href="javascript:history.back()" class="btn btn-outline btn-sm" style="margin-bottom:20px;">
                <i class="fa-solid fa-arrow-left"></i> Go Back
            </a>
            <div class="card animate-in glass-panel">
<% } else { %>
<div class="card animate-in glass-panel">
<% } %>

<% if (success) { %>
    <div class="alert alert-success animate-in"><i class="fa-solid fa-circle-check"></i> Profile updated successfully!</div>
<% } %>
<% if (error) { %>
    <div class="alert alert-danger animate-in"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
<% } %>

<div class="card animate-in glass-panel">
    <div class="card-header">
        <span class="card-title">
            <i class="fa-solid fa-user-circle"></i> <%= role %> Profile
        </span>
    </div>

    <!-- The form points to our common POST endpoint -->
    <form method="POST" action="/profile/update">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        
        <h4 style="margin-bottom: 12px; color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Account Details</h4>
        <div class="form-grid">
            <div class="form-group">
                <label>Username *</label>
                <input type="text" name="username" value="<%= user.username %>" required />
            </div>
            <div class="form-group">
                <label>Role (Read-only)</label>
                <input type="text" value="<%= user.role %>" disabled />
            </div>
            <div class="form-group">
                <label>Full Name *</label>
                <input type="text" name="full_name" value="<%= user.full_name %>" required />
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" value="<%= user.email || '' %>" placeholder="Primary Email" />
            </div>
        </div>

        <!-- Entity Specific Details -->
        <% if (role === 'Donor') { %>
            <hr style="border-color: var(--border-color); margin: 20px 0; border-style: dashed;" />
            <h4 style="margin-bottom: 12px; color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Donor Details</h4>
            
            <div class="form-grid">
                <div class="form-group">
                    <label>Mobile Number *</label>
                    <input type="text" name="phone" value="<%= entity ? entity.phone : '' %>" required />
                </div>
                <div class="form-group">
                    <label>Gender *</label>
                    <select name="gender" required>
                        <option value="Male" <%= (entity && entity.gender === 'Male') ? 'selected' : '' %>>Male</option>
                        <option value="Female" <%= (entity && entity.gender === 'Female') ? 'selected' : '' %>>Female</option>
                        <option value="Other" <%= (entity && entity.gender === 'Other') ? 'selected' : '' %>>Other</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Residential Address</label>
                <textarea name="address" rows="3"><%= entity && entity.address ? entity.address : '' %></textarea>
            </div>
        <% } else if (role === 'Hospital') { %>
            <hr style="border-color: var(--border-color); margin: 20px 0; border-style: dashed;" />
            <h4 style="margin-bottom: 12px; color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Hospital Details</h4>
            
            <div class="form-grid">
                <div class="form-group">
                    <label>Contact Phone *</label>
                    <input type="text" name="phone" value="<%= entity ? entity.phone : '' %>" required />
                </div>
                <div class="form-group">
                    <label>City *</label>
                    <input type="text" name="city" value="<%= entity ? entity.city : '' %>" required />
                </div>
                <div class="form-group">
                    <label>Contact Person</label>
                    <input type="text" name="contact_person" value="<%= entity ? entity.contact_person : '' %>" />
                </div>
                <div class="form-group">
                    <label>License Number *</label>
                    <input type="text" name="license_number" value="<%= entity ? entity.license_number : '' %>" required />
                </div>
            </div>
            <div class="form-group">
                <label>Institutional Address</label>
                <textarea name="address" rows="3"><%= entity && entity.address ? entity.address : '' %></textarea>
            </div>
        <% } else if (role === 'NGO') { %>
            <hr style="border-color: var(--border-color); margin: 20px 0; border-style: dashed;" />
            <h4 style="margin-bottom: 12px; color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">NGO Details</h4>

            <div class="form-grid">
                <div class="form-group">
                    <label>Contact Phone *</label>
                    <input type="text" name="phone" value="<%= entity ? entity.phone : '' %>" required />
                </div>
                <div class="form-group">
                    <label>City *</label>
                    <input type="text" name="city" value="<%= entity ? entity.city : '' %>" required />
                </div>
                <div class="form-group">
                    <label>Contact Person</label>
                    <input type="text" name="contact_person" value="<%= entity ? entity.contact_person : '' %>" />
                </div>
                <div class="form-group">
                    <label>Registration ID *</label>
                    <input type="text" name="registration_id" value="<%= entity ? entity.registration_id : '' %>" required />
                </div>
            </div>
            <div class="form-group">
                <label>Office Address</label>
                <textarea name="address" rows="3"><%= entity && entity.address ? entity.address : '' %></textarea>
            </div>
        <% } %>

        <div style="margin-top: 24px;">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Save Changes</button>
        </div>
    </form>
</div>

<% if (role !== 'Super Admin' && role !== 'Staff') { %>
        </div>
    </div>
</body>
</html>
<% } %>
