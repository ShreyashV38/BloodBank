<%# views/requests/index.ejs %>
    <% if (success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
        <% } %>
            <% if (typeof error==='string' && error) { %>
                <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i>
                    <%= error %>
                </div>
                <% } %>

                    <!-- Raise New Request -->
                    <div class="card">
                        <div class="card-header">
                            <span class="card-title"><i class="fa-solid fa-plus"></i> Raise New Blood Request</span>
                        </div>
                        <form method="POST" action="/requests/add">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Hospital *</label>
                                    <select name="hospital_id" required>
                                        <option value="">— Select Hospital —</option>
                                        <% hospitals.forEach(h=> { %>
                                            <option value="<%= h.hospital_id %>">
                                                <%= h.name %> (<%= h.city || '—' %>)
                                            </option>
                                            <% }); %>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Blood Group *</label>
                                    <select name="blood_group_id" required>
                                        <option value="">— Select Group —</option>
                                        <% bloodGroups.forEach(bg=> { %>
                                            <option value="<%= bg.blood_group_id %>">
                                                <%= bg.group_name %>
                                            </option>
                                            <% }); %>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Units Required *</label>
                                    <input type="number" name="units_required" required min="0.5" step="0.5"
                                        placeholder="e.g., 2" />
                                </div>
                                <div class="form-group">
                                    <label>Urgency *</label>
                                    <select name="urgency" required>
                                        <option value="Normal">Normal</option>
                                        <option value="Urgent">Urgent</option>
                                        <option value="Critical">Critical</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Required By Date</label>
                                    <input type="date" name="required_by_date" />
                                </div>
                                <div class="form-group">
                                    <label>Purpose</label>
                                    <input type="text" name="purpose" placeholder="e.g., Emergency surgery" />
                                </div>
                            </div>
                            <div style="margin-top:16px;">
                                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i>
                                    Submit Request</button>
                            </div>
                        </form>
                    </div>

                    <!-- Pending Requests -->
                    <div class="card">
                        <div class="card-header">
                            <span class="card-title"><i class="fa-solid fa-clock"></i> Pending Requests (<%=
                                    pending.length %>)</span>
                        </div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>#ID</th>
                                        <th>Hospital</th>
                                        <th>City</th>
                                        <th>Blood</th>
                                        <th>Units</th>
                                        <th>Urgency</th>
                                        <th>Required By</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (pending.length===0) { %>
                                        <tr>
                                            <td colspan="8"
                                                style="text-align:center;color:var(--text-muted);padding:28px;">🎉 No
                                                pending requests!</td>
                                        </tr>
                                        <% } %>
                                            <% pending.forEach(r=> { %>
                                                <tr>
                                                    <td><span class="badge badge-gray">#<%= r.request_id %></span></td>
                                                    <td style="font-weight:600">
                                                        <%= r.hospital_name %>
                                                    </td>
                                                    <td>
                                                        <%= r.city || '—' %>
                                                    </td>
                                                    <td><span class="badge badge-danger">
                                                            <%= r.group_name %>
                                                        </span></td>
                                                    <td>
                                                        <%= r.units_required %>
                                                    </td>
                                                    <td><span class="urgency-<%= r.urgency %>">
                                                            <%= r.urgency %>
                                                        </span></td>
                                                    <td style="color:var(--text-muted);font-size:.8rem">
                                                        <%= r.required_by_date ? new
                                                            Date(r.required_by_date).toDateString() : '—' %>
                                                    </td>
                                                    <td>
                                                        <!-- Approve Modal Trigger -->
                                                        <button class="btn btn-success btn-sm"
                                                            onclick="openApprove(<%= r.request_id %>, '<%= r.units_required %>')">
                                                            <i class="fa-solid fa-check"></i> Approve
                                                        </button>
                                                        <form method="POST"
                                                            action="/requests/reject/<%= r.request_id %>"
                                                            style="display:inline"
                                                            onsubmit="return confirm('Reject this request?')">
                                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                                            <button class="btn btn-danger btn-sm"><i
                                                                    class="fa-solid fa-xmark"></i> Reject</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Request History -->
                    <div class="card">
                        <div class="card-header">
                            <span class="card-title"><i class="fa-solid fa-history"></i> Recent History</span>
                        </div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>#ID</th>
                                        <th>Hospital</th>
                                        <th>Blood</th>
                                        <th>Units</th>
                                        <th>Urgency</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (history.length===0) { %>
                                        <tr>
                                            <td colspan="7"
                                                style="text-align:center;color:var(--text-muted);padding:24px;">No
                                                history yet.</td>
                                        </tr>
                                        <% } %>
                                            <% history.forEach(r=> {
                                                const sc =
                                                {Fulfilled:'badge-success',Rejected:'badge-danger',Approved:'badge-info',Pending:'badge-warning'};
                                                %>
                                                <tr>
                                                    <td><span class="badge badge-gray">#<%= r.request_id %></span></td>
                                                    <td>
                                                        <%= r.hospital_name %>
                                                    </td>
                                                    <td><span class="badge badge-danger">
                                                            <%= r.group_name %>
                                                        </span></td>
                                                    <td>
                                                        <%= r.units_required %>
                                                    </td>
                                                    <td><span class="urgency-<%= r.urgency %>">
                                                            <%= r.urgency %>
                                                        </span></td>
                                                    <td><span class="badge <%= sc[r.status] || 'badge-gray' %>">
                                                            <%= r.status %>
                                                        </span></td>
                                                    <td style="color:var(--text-muted);font-size:.8rem">
                                                        <%= new Date(r.request_date).toDateString() %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Approve Modal -->
                    <div id="approveModal"
                        style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:999;align-items:center;justify-content:center;">
                        <div
                            style="background:var(--bg-secondary, #1a1a2e);border-radius:16px;padding:32px;width:420px;box-shadow:0 20px 60px rgba(0,0,0,.5);border:1px solid var(--border-color, #2a2a3e);">
                            <h3 style="margin-bottom:20px;"><i class="fa-solid fa-check-circle"
                                    style="color:var(--success)"></i> Approve Request #<span id="modalReqId"></span>
                            </h3>
                            <form method="POST" id="approveForm">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <div class="form-group" style="margin-bottom:14px;">
                                    <label>Inventory ID to draw from *</label>
                                    <input type="number" name="inventory_id" id="modalInvId" required
                                        placeholder="e.g., 1" />
                                </div>
                                <div class="form-group" style="margin-bottom:20px;">
                                    <label>Units to Provide *</label>
                                    <input type="number" name="units_provided" id="modalUnits" required step="0.5" />
                                </div>
                                <div style="display:flex;gap:10px;">
                                    <button type="submit" class="btn btn-success"><i class="fa-solid fa-check"></i>
                                        Confirm Approve</button>
                                    <button type="button" class="btn btn-outline"
                                        onclick="closeApprove()">Cancel</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <script src="/js/requests.js"></script>